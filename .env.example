# Resend (envoi d'emails) — compte gratuit sur resend.com
# 3000 emails/mois gratuits
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# L'email qui recevra les demandes d'inscription
ADMIN_EMAIL=ton@email.com

# Ton domaine (doit être vérifié dans Resend)
# Si pas encore de domaine, utilise le domaine Resend par défaut pendant les tests
EMAIL_DOMAIN=tondomaine.com

# Cloudflare Turnstile — compte gratuit sur dash.cloudflare.com/turnstile
# La clé secrète (à ne jamais mettre dans le code front)
TURNSTILE_SECRET_KEY=0xAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Origine autorisée pour les requêtes CORS (ton domaine en prod)
ALLOWED_ORIGIN=https://tondomaine.com
